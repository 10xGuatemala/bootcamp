{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "color": {
    "brand": {
      "primary":   { "$value": "#0d4d92", "$type": "color", "$description": "Acción principal, enlaces, foco" },
      "secondary": { "$value": "#ef9b50", "$type": "color", "$description": "Acento — nunca para acciones críticas" }
    },
    "neutral": {
      "900": { "$value": "#1a2f4d", "$type": "color" },
      "700": { "$value": "#3a4a66", "$type": "color" },
      "500": { "$value": "#6b7a94", "$type": "color" },
      "300": { "$value": "#c8d0de", "$type": "color" },
      "100": { "$value": "#f2f4f8", "$type": "color" },
      "000": { "$value": "#ffffff", "$type": "color" }
    },
    "semantic": {
      "success": { "$value": "#2f8f5a", "$type": "color" },
      "warning": { "$value": "#b5791f", "$type": "color" },
      "danger":  { "$value": "#b33a3a", "$type": "color" },
      "info":    { "$value": "#2b6cb0", "$type": "color" }
    }
  },
  "font": {
    "family": {
      "base":    { "$value": "'Source Sans 3', system-ui, sans-serif", "$type": "fontFamily" },
      "heading": { "$value": "'Space Grotesk', system-ui, sans-serif", "$type": "fontFamily" },
      "mono":    { "$value": "'JetBrains Mono', ui-monospace, monospace", "$type": "fontFamily" }
    },
    "size": {
      "xs":   { "$value": "0.75rem", "$type": "dimension" },
      "sm":   { "$value": "0.875rem", "$type": "dimension" },
      "base": { "$value": "1rem", "$type": "dimension" },
      "lg":   { "$value": "1.125rem", "$type": "dimension" },
      "xl":   { "$value": "1.25rem", "$type": "dimension" },
      "2xl":  { "$value": "1.5rem", "$type": "dimension" },
      "3xl":  { "$value": "1.875rem", "$type": "dimension" }
    },
    "weight": {
      "regular":  { "$value": 400, "$type": "fontWeight" },
      "medium":   { "$value": 500, "$type": "fontWeight" },
      "semibold": { "$value": 650, "$type": "fontWeight" },
      "bold":     { "$value": 700, "$type": "fontWeight" }
    }
  },
  "spacing": {
    "0": { "$value": "0", "$type": "dimension" },
    "1": { "$value": "0.25rem", "$type": "dimension" },
    "2": { "$value": "0.5rem", "$type": "dimension" },
    "3": { "$value": "0.75rem", "$type": "dimension" },
    "4": { "$value": "1rem", "$type": "dimension" },
    "6": { "$value": "1.5rem", "$type": "dimension" },
    "8": { "$value": "2rem", "$type": "dimension" }
  },
  "radius": {
    "sm":   { "$value": "0.25rem", "$type": "dimension" },
    "md":   { "$value": "0.5rem", "$type": "dimension" },
    "lg":   { "$value": "1rem", "$type": "dimension" },
    "full": { "$value": "9999px", "$type": "dimension" }
  },
  "shadow": {
    "sm": { "$value": "0 1px 2px rgba(0,0,0,0.06)", "$type": "shadow" },
    "md": { "$value": "0 4px 12px rgba(0,0,0,0.08)", "$type": "shadow" },
    "lg": { "$value": "0 12px 32px rgba(0,0,0,0.12)", "$type": "shadow" }
  }
}
